<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<DialogPane stylesheets="@./main.css" styleClass="dialog-pane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ihm.main_controllers.ControllerParametres">
    <content>
        <ScrollPane fitToWidth="true" styleClass="console-scroll">
            <VBox spacing="0">
                <Label text="⚙ PARAMÈTRES" styleClass="panel-title" />
                <Region styleClass="separator-line" prefHeight="1.0" />

                <Label text="SON" styleClass="btn-group-label" />
                <VBox spacing="8" style="-fx-padding: 12 16 12 16;">
                    <VBox spacing="4">
                        <Label text="Musique d'ambiance" styleClass="dialog-label" />
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Slider fx:id="sliderVolume" min="0" max="100" value="70" prefWidth="200" />
                            <Label fx:id="labelVolumeValue" text="70%" styleClass="dialog-label" style="-fx-min-width: 35;" />
                        </HBox>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Bruitages (SFX)" styleClass="dialog-label" />
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Slider fx:id="sliderSfx" min="0" max="100" value="70" prefWidth="200" />
                            <Label fx:id="labelSfxValue" text="70%" styleClass="dialog-label" style="-fx-min-width: 35;" />
                        </HBox>
                    </VBox>
                    <CheckBox fx:id="cbMuet" text="Mode muet (Musique)" styleClass="dialog-label-sub" />
                </VBox>
                <Region styleClass="separator-line" prefHeight="1.0" />

                <Label text="AFFICHAGE" styleClass="btn-group-label" />
                <VBox spacing="8" style="-fx-padding: 12 16 12 16;">
                    <CheckBox fx:id="cbAutoScroll" text="Défilement automatique du chat" styleClass="dialog-label-sub" />
                    <CheckBox fx:id="cbTimestamp" text="Afficher l'heure des messages" styleClass="dialog-label-sub" />
                </VBox>
                <Region styleClass="separator-line" prefHeight="1.0" />

                <Label text="JEU &amp; CHAT" styleClass="btn-group-label" />
                <VBox spacing="8" style="-fx-padding: 12 16 12 16;">
                    <CheckBox fx:id="cbConfirmFinTour" text="Demander confirmation avant la fin du tour" styleClass="dialog-label-sub" />
                    <CheckBox fx:id="cbMessagePublic" text="Autoriser la messagerie publique" styleClass="dialog-label-sub" />
                    <CheckBox fx:id="cbMessagePrive" text="Autoriser la messagerie privée" styleClass="dialog-label-sub" />
                    <CheckBox fx:id="cbDes" text="Autoriser le lancer de dés" styleClass="dialog-label-sub" />
                    <CheckBox fx:id="cbMouvement" text="Autoriser les déplacements" styleClass="dialog-label-sub" />
                </VBox>
                <Region styleClass="separator-line" prefHeight="1.0" />

                <HBox spacing="12" style="-fx-padding: 12 16 16 16;" alignment="CENTER_LEFT">
                    <Button fx:id="btnResetDefault" text="Réinitialiser" styleClass="btn-secondary" />
                </HBox>
            </VBox>
        </ScrollPane>
    </content>
    <buttonTypes>
        <ButtonType fx:constant="OK" />
    </buttonTypes>
</DialogPane>