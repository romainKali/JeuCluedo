<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonType?>
<?import javafx.scene.control.DialogPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
    refuter.fxml — DialogPane chargé via FXMLLoader dans ControllerMain.dialogueRefuter()
    fx:id injectés dans RefuterController :
      - personnageButton : Button  (setGraphic avec ImageView depuis PERSON_MAP)
      - armeButton       : Button  (setGraphic avec ImageView depuis ARME_MAP)
      - lieuButton       : Button  (setGraphic avec ImageView depuis LIEU_MAP)
      - nullButton       : Button  (affiché/activé seulement si le joueur n'a aucune carte)
    handleOptionClick() ferme la fenêtre après sélection → les boutons OK/CANCEL restent
    mais l'action principale passe par handleOptionClick (qui appelle stage.close())
-->
<DialogPane stylesheets="@./main.css"
            styleClass="dialog-pane"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ihm.main_controllers.RefuterController">
    <content>
        <VBox alignment="CENTER" spacing="16">
            <padding><Insets top="16" right="20" bottom="8" left="20" /></padding>

            <Label text="🚫  RÉFUTATION" styleClass="panel-title" maxWidth="Infinity" />
            <Region styleClass="separator-line" prefHeight="1.0" maxWidth="Infinity" />

            <Region prefHeight="4" />
            <Label text="Choisissez une carte à montrer :"
                   styleClass="dialog-label-sub" />

            <HBox alignment="CENTER" spacing="14">
                <!-- Les graphiques (ImageView) sont injectés par initRefuter() -->
                <Button fx:id="personnageButton"
                        onAction="#handleOptionClick"
                        styleClass="btn-card"
                        prefWidth="110" prefHeight="110" />

                <Button fx:id="armeButton"
                        onAction="#handleOptionClick"
                        styleClass="btn-card"
                        prefWidth="110" prefHeight="110" />

                <Button fx:id="lieuButton"
                        onAction="#handleOptionClick"
                        styleClass="btn-card"
                        prefWidth="110" prefHeight="110" />
            </HBox>

            <!-- Visible et actif uniquement si aucune carte (géré par initRefuter()) -->
            <Button fx:id="nullButton"
                    text="Je n'ai aucune de ces cartes"
                    onAction="#handleOptionClick"
                    disable="true"
                    managed="false"
                    styleClass="btn-no-card" />

            <Region prefHeight="4" />
        </VBox>
    </content>
    <buttonTypes>
        <ButtonType fx:constant="OK" />
        <ButtonType fx:constant="CANCEL" />
    </buttonTypes>
</DialogPane>
